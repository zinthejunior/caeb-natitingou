# ─────────────────────────────────────────────────────────────────
# .env.example — Variables d'environnement du backend Django (CAEB)
# Copier ce fichier en .env et remplir les valeurs réelles.
# NE JAMAIS commiter le fichier .env dans Git.
# ─────────────────────────────────────────────────────────────────

# ── Django ────────────────────────────────────────────────────
SECRET_KEY='django-insecure-clé-généré'
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================================
# CONFIGURATION BASE DE DONNÉES POSTGRESQL (LOCAL)
# ============================================================

# Nom de la base PostgreSQL
# Par défaut : 'caeb_bibliotheque'
DB_NAME=caeb_bibliotheque

# Utilisateur PostgreSQL
# Par défaut : 'postgres'
DB_USER=postgres

# Mot de passe PostgreSQL
# ⚠️ Ne jamais partager ce mot de passe publiquement
DB_PASSWORD=postgres

# Adresse du serveur PostgreSQL
# Par défaut : 'localhost' (votre machine locale)
DB_HOST=localhost

# Port PostgreSQL
# Par défaut : 5432 (port standard PostgreSQL)
DB_PORT=5432


# ============================================================
# CONFIGURATION CORS
# ============================================================

# Liste des URLs autorisées à accéder à l’API backend
# Séparées par des virgules
# localhost:5173 → Vite
# localhost:3000 → React/Next.js
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000


# ============================================================
DEFAULT_FROM_EMAIL=no-reply@caeb-natitingou.org
