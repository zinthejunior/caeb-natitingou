# ========================================================================================
# 🔒 CONFIGURATION FASTAPI - FICHIER D'EXEMPLE (.env.example)
# ========================================================================================
# ⚠️ ATTENTION: Ne JAMAIS commiter le fichier .env réel avec les secrets !
# Ce fichier est un template - copie-le dans .env et remplis les valeurs réelles.
#
# Commande pour créer .env depuis ce template:
#   cp .env.example .env
#
# ========================================================================================
 
# ── Backend Django API ────────────────────────────────────────────────────────────────
# URL de base du backend Django pour les appels API
BACKEND_API_URL=http://localhost:8080/api

# ── Modèles IA (LLM) ─────────────────────────────────────────────────────────────────
# OpenRouter API Key - Nécessaire pour les requêtes LLM
# Voir: https://openrouter.ai/
# 🔒 SECRET: Ne pas partager cette clé !
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx

# ── APIs de recherche (optionnel) ─────────────────────────────────────────────────────
# SerpAPI Key pour recherche Google personnalisée
# Voir: https://serpapi.com/
SERPAPI_API_KEY=

# Bing Search API Key
# Voir: https://www.microsoft.com/en-us/bing/apis/bing-web-search-api
BING_SEARCH_API_KEY=

# ── CORS ──────────────────────────────────────────────────────────────────────────────
# Origines autorisées pour les requêtes CORS (séparées par des virgules)
# En développement: http://localhost:5173,http://localhost:3000
# En production: https://example.com
CORS_ORIGINS=http://localhost:5173,http://localhost:3000